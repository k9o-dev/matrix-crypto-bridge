# Rust
/target/
**/*.rs.bk
# Cargo.lock is intentionally NOT ignored — it is tracked in git.
# Committing Cargo.lock ensures CI always builds with the exact same uniffi
# crate version that was used to generate the committed Swift bindings.
# A uniffi version mismatch causes SIGILL at startup (contract version check).
# !Cargo.lock

# iOS
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.xcframework/
*.framework/
build/
DerivedData/

# Android
.gradle/
local.properties
*.iml
.idea/
build/
*.apk
*.aar
.DS_Store

# Node
node_modules/
npm-debug.log
yarn-error.log
dist/
lib/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Generated files
matrix-crypto-ios/generated/
matrix-crypto-android/generated/

# Generated libraries
*.so
*.a
*.m
*.rlib

# Allow Objective-C bridge files in React Native packages
!react-native-matrix-crypto/ios/*.m

